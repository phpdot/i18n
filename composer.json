{
    "name": "phpdot/i18n",
    "description": "Internationalization with ICU MessageFormat, pluggable loaders, PSR-16 caching.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["i18n", "internationalization", "translation", "icu", "messageformat", "locale", "psr-16"],
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "psr/simple-cache": "^3.0"
    },
    "extra": {
        "phpdot": {
            "package": "PHPdot\\I18n\\I18nPackage"
        }
    },
    "suggest": {
        "phpdot/cache": "PSR-16 cache implementation for production caching"
    },
    "require-dev": {
        "phpdot/package": "^1.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\I18n\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\I18n\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
